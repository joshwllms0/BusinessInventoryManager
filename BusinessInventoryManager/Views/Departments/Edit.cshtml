@model BusinessInventoryManager.Models.Department

@{
    ViewData["Title"] = "Edit Department";
}

<div class="form-page">
    <div class="page-header">
        <div>
            <span class="eyebrow">Departments</span>
            <h1>Edit Department</h1>
            <p>Update department name or description.</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="DepartmentId" />

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="DepartmentName"></label>
                <input asp-for="DepartmentName" />
                <span asp-validation-for="DepartmentName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description"
                      class="validation-message"></span>
            </div>

            <div class="button-row">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}