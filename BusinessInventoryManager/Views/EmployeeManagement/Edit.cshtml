@model BusinessInventoryManager.ViewModels.Employees.EditEmployeeViewModel

@{
    ViewData["Title"] = "Edit Employee";
}

<div class="page-header">
    <div>
        <span class="eyebrow">Employee accounts</span>
        <h1>Edit Employee</h1>
        <p>
            Update account details, role, department,
            assigned manager, or account status.
        </p>
    </div>

    <a asp-action="Index"
       class="btn btn-secondary">
        Cancel
    </a>
</div>

<form asp-action="Edit"
      asp-route-id="@Model.Id"
      method="post"
      class="form-card">

    <input asp-for="Id" type="hidden" />

    <div asp-validation-summary="ModelOnly"
         class="validation-summary"></div>

    <div class="form-grid">
        <div class="form-group">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" />
            <span asp-validation-for="FirstName"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" />
            <span asp-validation-for="LastName"
                  class="validation-message"></span>
        </div>

        <div class="form-group form-group-wide">
            <label asp-for="Email"></label>
            <input asp-for="Email" />
            <span asp-validation-for="Email"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Role"></label>
            <select asp-for="Role"
                    asp-items="Model.Roles">
            </select>
            <span asp-validation-for="Role"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentId"></label>
            <select asp-for="DepartmentId"
                    asp-items="Model.Departments">
                <option value="">Unassigned</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="ManagerId"></label>
            <select asp-for="ManagerId"
                    asp-items="Model.Managers">
                <option value="">No assigned manager</option>
            </select>
            <span asp-validation-for="ManagerId"
                  class="validation-message"></span>
        </div>

        <div class="form-group form-group-wide">
            <label class="checkbox-row">
                <input asp-for="IsActive" />
                <span>Account is active</span>
            </label>

            <p class="field-help">
                Inactive accounts cannot sign in, but their historical
                inventory activity remains available.
            </p>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit"
                class="btn btn-primary">
            Save Changes
        </button>

        <a asp-action="Index"
           class="btn btn-secondary">
            Cancel
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}