@model BusinessInventoryManager.ViewModels.Employees.CreateEmployeeViewModel

@{
    ViewData["Title"] = "Add Employee";
}

<div class="page-header">
    <div>
        <span class="eyebrow">Employee accounts</span>
        <h1>Add Employee</h1>
        <p>Create a secure account and assign its role and department.</p>
    </div>

    <a asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</div>

<form asp-action="Create"
      method="post"
      class="form-card">

    <div asp-validation-summary="ModelOnly"
         class="validation-summary"></div>

    <div class="form-grid">
        <div class="form-group">
            <label asp-for="FirstName"></label>
            <input asp-for="FirstName" />
            <span asp-validation-for="FirstName"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="LastName"></label>
            <input asp-for="LastName" />
            <span asp-validation-for="LastName"
                  class="validation-message"></span>
        </div>

        <div class="form-group form-group-wide">
            <label asp-for="Email"></label>
            <input asp-for="Email"
                   autocomplete="off" />
            <span asp-validation-for="Email"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Password"></label>
            <input asp-for="Password"
                   autocomplete="new-password" />
            <span asp-validation-for="Password"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="ConfirmPassword"></label>
            <input asp-for="ConfirmPassword"
                   autocomplete="new-password" />
            <span asp-validation-for="ConfirmPassword"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="Role"></label>
            <select asp-for="Role"
                    asp-items="Model.Roles">
            </select>
            <span asp-validation-for="Role"
                  class="validation-message"></span>
        </div>

        <div class="form-group">
            <label asp-for="DepartmentId"></label>
            <select asp-for="DepartmentId"
                    asp-items="Model.Departments">
                <option value="">Unassigned</option>
            </select>
        </div>

        <div class="form-group">
            <label asp-for="ManagerId"></label>
            <select asp-for="ManagerId"
                    asp-items="Model.Managers">
                <option value="">No assigned manager</option>
            </select>
        </div>
    </div>

    <div class="form-actions">
        <button type="submit" class="btn btn-primary">
            Create Employee
        </button>

        <a asp-action="Index" class="btn btn-secondary">
            Cancel
        </a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}