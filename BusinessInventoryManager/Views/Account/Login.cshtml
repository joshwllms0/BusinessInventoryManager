@model BusinessInventoryManager.ViewModels.Account.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="login-page">
    <section class="login-card">
        <div class="login-heading">
            <span class="eyebrow">Secure employee access</span>
            <h1>Sign in</h1>
            <p>Enter your employee account credentials to access the inventory system.</p>
        </div>

        <form asp-controller="Account"
              asp-action="Login"
              method="post">

            <input asp-for="ReturnUrl" type="hidden" />

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email"
                       autocomplete="username"
                       placeholder="name@business.com" />
                <span asp-validation-for="Email"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password"
                       autocomplete="current-password"
                       placeholder="Enter your password" />
                <span asp-validation-for="Password"
                      class="validation-message"></span>
            </div>

            <label class="checkbox-row">
                <input asp-for="RememberMe" />
                <span>Remember me on this device</span>
            </label>

            <button type="submit"
                    class="btn btn-primary login-button">
                Sign In
            </button>
        </form>

        <p class="login-help">
            Don't have an account? <a asp-action="Register">Register here</a>
        </p>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}