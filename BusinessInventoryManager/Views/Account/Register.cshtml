@model BusinessInventoryManager.ViewModels.Account.RegisterViewModel

@{
    ViewData["Title"] = "Register";
}

<div class="login-page">
    <section class="login-card">
        <div class="login-heading">
            <span class="eyebrow">Create your account</span>
            <h1>Register</h1>
            <p>Set up your employee account to access the inventory system.</p>
        </div>

        <form asp-controller="Account"
              asp-action="Register"
              method="post">

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="FirstName"></label>
                <input asp-for="FirstName"
                       placeholder="First name" />
                <span asp-validation-for="FirstName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="LastName"></label>
                <input asp-for="LastName"
                       placeholder="Last name" />
                <span asp-validation-for="LastName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Email"></label>
                <input asp-for="Email"
                       autocomplete="username"
                       placeholder="name@business.com" />
                <span asp-validation-for="Email"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Password"></label>
                <input asp-for="Password"
                       autocomplete="new-password"
                       placeholder="Min. 8 characters" />
                <span asp-validation-for="Password"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="ConfirmPassword"></label>
                <input asp-for="ConfirmPassword"
                       autocomplete="new-password"
                       placeholder="Re-enter your password" />
                <span asp-validation-for="ConfirmPassword"
                      class="validation-message"></span>
            </div>

            <button type="submit"
                    class="btn btn-primary login-button">
                Create Account
            </button>
        </form>

        <p class="login-help">
            Already have an account?
            <a asp-action="Login">Sign in here</a>
        </p>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}