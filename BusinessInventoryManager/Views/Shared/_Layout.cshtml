<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Business Inventory Manager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
        <nav class="nav">
            <a class="brand" asp-controller="Home" asp-action="Index">Business Inventory Manager</a>
            <div class="nav-links">
                <a asp-controller="Home" asp-action="Index">Home</a>
                <a asp-controller="Inventory" asp-action="Index">Inventory</a>
                <a asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>&copy; 2026 - Business Inventory Manager</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
