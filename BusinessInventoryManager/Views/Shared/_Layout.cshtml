<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Business Inventory Manager</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="site-header">
    <nav class="nav">
        <a class="brand"
           asp-controller="Dashboard"
           asp-action="Index">
            Business Inventory Manager
        </a>

        <div class="nav-links">
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Dashboard"
                   asp-action="Index">
                    Dashboard
                </a>

                <a asp-controller="Products"
                   asp-action="Index">
                    Products
                </a>

                <a asp-controller="InventoryTransactions"
                   asp-action="History">
                    Stock Activity
                </a>

                @if (User.IsInRole("Manager"))
                {
                    <a asp-controller="EmployeeManagement"
                       asp-action="Index">
                        Employees
                    </a>

                    <a asp-controller="Reports"
                       asp-action="Index">
                        Reports
                    </a>
                }
            }

            <partial name="_LoginPartial" />
        </div>
    </nav>
</header>

    <main class="container">
        @RenderBody()
    </main>

    <footer class="footer">
        <p>&copy; 2026 - Business Inventory Manager</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
