@model IEnumerable<BusinessInventoryManager.Models.Product>

<div class="table-card">
    <table class="inventory-table">
        <thead>
            <tr>
                <th>SKU</th>
                <th>Product</th>
                <th>Brand</th>
                <th>Department</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Price</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Any())
            {
                foreach (var product in Model)
                {
                    <tr class="@(product.QuantityInStock < 5
                        ? "low-stock-row"
                        : "")">
                        <td>@product.SKU</td>
                        <td>@product.ProductName</td>
                        <td>@product.Brand.BrandName</td>
                        <td>
                            @product.Category.Department.DepartmentName
                        </td>
                        <td>@product.Category.CategoryName</td>
                        <td>@product.QuantityInStock</td>
                        <td>@product.UnitPrice.ToString("C")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="empty-message">
                        No matching products were found.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>