@model BusinessInventoryManager.Models.Category

@{
    ViewData["Title"] = "Add Category";
}

<div class="form-page">
    <div class="page-header">
        <div>
            <span class="eyebrow">Categories</span>
            <h1>Add Category</h1>
            <p>Create a new category and assign it to a department.</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

    <div class="form-card">
        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="DepartmentId">Department</label>
                <select asp-for="DepartmentId"
                        asp-items="ViewBag.Departments">
                    <option value="">Select department</option>
                </select>
                <span asp-validation-for="DepartmentId"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="CategoryName"></label>
                <input asp-for="CategoryName"
                       placeholder="e.g. Ice Cream" />
                <span asp-validation-for="CategoryName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description"
                          rows="3"
                          placeholder="Optional description"></textarea>
                <span asp-validation-for="Description"
                      class="validation-message"></span>
            </div>

            <div class="button-row">
                <button type="submit" class="btn btn-primary">Save Category</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}