@model BusinessInventoryManager.Models.Category

@{
    ViewData["Title"] = "Edit Category";
}

<div class="form-page">
    <div class="page-header">
        <div>
            <span class="eyebrow">Categories</span>
            <h1>Edit Category</h1>
            <p>Update category name, department, or description.</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="CategoryId" />

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="DepartmentId">Department</label>
                <select asp-for="DepartmentId"
                        asp-items="ViewBag.Departments">
                    <option value="">Select department</option>
                </select>
                <span asp-validation-for="DepartmentId"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="CategoryName"></label>
                <input asp-for="CategoryName" />
                <span asp-validation-for="CategoryName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description"
                      class="validation-message"></span>
            </div>

            <div class="button-row">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}