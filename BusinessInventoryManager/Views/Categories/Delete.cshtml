@model BusinessInventoryManager.Models.Category

@{
    ViewData["Title"] = "Delete Category";
}

<div class="form-page">
    <div class="page-header">
        <div>
            <span class="eyebrow">Categories</span>
            <h1>Delete Category</h1>
        </div>
    </div>

    <div class="warning-card delete-card">
        <p>
            Are you sure you want to delete
            <strong>@Model.CategoryName</strong>
            from <strong>@Model.Department.DepartmentName</strong>?
        </p>

        @if (Model.Products.Any())
        {
            <p class="validation-message">
                This category cannot be deleted because it has
                <strong>@Model.Products.Count</strong> active product(s) assigned to it.
                Remove or reassign those products first.
            </p>
            <a asp-action="Index" class="btn btn-secondary">Back to Categories</a>
        }
        else
        {
            <p>This action is permanent and cannot be undone.</p>

            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="CategoryId" />
                <div class="button-row">
                    <button type="submit" class="btn btn-danger">Delete Category</button>
                    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        }
    </div>
</div>