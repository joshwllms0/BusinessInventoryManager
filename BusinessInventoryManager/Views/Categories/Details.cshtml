@model BusinessInventoryManager.Models.Category

@{
    ViewData["Title"] = Model.CategoryName;
}

<div class="page-header">
    <div>
        <span class="eyebrow">@Model.Department.DepartmentName</span>
        <h1>@Model.CategoryName</h1>
        <p>@(Model.Description ?? "No description provided.")</p>
    </div>
    <div class="page-actions">
        <a asp-action="Edit"
           asp-route-id="@Model.CategoryId"
           class="btn btn-primary">Edit Category</a>
        <a asp-action="Index"
           class="btn btn-secondary">Back to Categories</a>
    </div>
</div>

<div class="table-card">
    <h2>Products in This Category</h2>
    <table class="inventory-table">
        <thead>
            <tr>
                <th>Product Name</th>
                <th>SKU</th>
                <th>Stock</th>
                <th>Price</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Products.Any())
            {
                foreach (var product in Model.Products.OrderBy(p => p.ProductName))
                {
                    <tr>
                        <td>
                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@product.ProductId">
                                @product.ProductName
                            </a>
                        </td>
                        <td>@product.SKU</td>
                        <td>
                            <span class="stock-badge @(product.QuantityInStock <= product.ReorderLevel ? "stock-low" : "stock-normal")">
                                @product.QuantityInStock
                            </span>
                        </td>
                        <td>@product.UnitPrice.ToString("C")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="4" class="empty-message">
                        No active products in this category.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>