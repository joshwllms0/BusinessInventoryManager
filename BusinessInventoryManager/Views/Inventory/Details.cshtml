@model BusinessInventoryManager.Models.Inventory

@{
    ViewData["Title"] = "Item Details";
}

<div class="page-header">
    <div>
        <h1>@Model.ItemName</h1>
        <p>Inventory item details.</p>
    </div>

    <div class="button-row">
        <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
        <a class="btn btn-secondary" asp-action="Index">Back to Inventory</a>
    </div>
</div>

<section class="details-card">
    <div class="detail-row">
        <span>Item Name</span>
        <strong>@Model.ItemName</strong>
    </div>

    <div class="detail-row">
        <span>Description</span>
        <strong>@(string.IsNullOrWhiteSpace(Model.ItemDescription) ? "No description provided" : Model.ItemDescription)</strong>
    </div>

    <div class="detail-row">
        <span>Category</span>
        <strong>@Model.Category</strong>
    </div>

    <div class="detail-row">
        <span>Stock</span>
        <strong>
            @Model.Stock
            @if (Model.Stock < 10)
            {
                <span class="badge">Low Stock</span>
            }
        </strong>
    </div>

    <div class="detail-row">
        <span>Unit Price</span>
        <strong>@Model.Price.ToString("C")</strong>
    </div>

    <div class="detail-row">
        <span>Total Value</span>
        <strong>@((Model.Stock * Model.Price).ToString("C"))</strong>
    </div>
</section>
