@model BusinessInventoryManager.Models.Inventory

@{
    ViewData["Title"] = "Delete Item";
}

<div class="form-page">
    <h1>Delete Item</h1>

    <div class="warning-card">
        <h2>Are you sure you want to delete @Model.ItemName?</h2>
        <p>This action will permanently remove this item from the inventory list.</p>

        <dl class="delete-details">
            <dt>Category</dt>
            <dd>@Model.Category</dd>

            <dt>Stock</dt>
            <dd>@Model.Stock</dd>

            <dt>Price</dt>
            <dd>@Model.Price.ToString("C")</dd>
        </dl>

        <form asp-action="Delete" method="post">
            <input type="hidden" asp-for="Id" />

            <div class="button-row">
                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
