@model IEnumerable<BusinessInventoryManager.Models.Inventory>

@{
    ViewData["Title"] = "Inventory";

    var totalItems = Model?.Count() ?? 0;
    var totalValue = Model?.Sum(item => item.Stock * item.Price) ?? 0;
    var lowStockCount = Model?.Count(item => item.Stock < 10) ?? 0;
}

<div class="page-header">
    <div>
        <h1>Inventory</h1>
        <p>View and manage all inventory items.</p>
    </div>

    <a class="btn btn-primary" asp-action="Create">Create New Item</a>
</div>

<section class="summary-grid">
    <div class="summary-card">
        <span>Total Items</span>
        <strong>@totalItems</strong>
    </div>

    <div class="summary-card">
        <span>Low Stock Items</span>
        <strong>@lowStockCount</strong>
    </div>

    <div class="summary-card">
        <span>Total Inventory Value</span>
        <strong>@totalValue.ToString("C")</strong>
    </div>
</section>

<form method="get" asp-action="Index" class="filter-bar">
    <input type="text" name="search" value="@ViewBag.CurrentSearch" placeholder="Search by name..." />
    <select name="category">
        <option value="">All Categories</option>

        @foreach (var cat in Enum.GetValues<Category>())
        {
            <option value="@cat" selected="@(ViewBag.CurrentCategory?.ToString() == cat.ToString())">@cat</option>
        }
    </select>

    <select name="sort">
        <option value="">Sort: Default</option>
        <option value="stock_asc" selected="@(ViewBag.CurrentSort == "stock_asc")">Stock: Low to High</option>
        <option value="price_desc" selected="@(ViewBag.CurrentSort == "price_desc")">Price: High to Low</option>
    </select>

    <button type="submit" class="btn btn-primary">Apply</button>
    <a asp-action="Index" class="btn btn-secondary">Clear</a>
</form>

<div class="table-card">
    <table class="inventory-table">
        <thead>
            <tr>
                <th>Item Name</th>
                <th>Category</th>
                <th>Stock</th>
                <th>Price</th>
                <th class="actions-column">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                foreach (var item in Model)
                {
                    <tr class="@(item.Stock < 10 ? "low-stock-row" : "")">
                        <td>
                            <strong>@item.ItemName</strong>
                            @if (item.Stock < 10)
                            {
                                <span class="badge">Low Stock</span>
                            }
                        </td>
                        <td>@item.Category</td>
                        <td>@item.Stock</td>
                        <td>@item.Price.ToString("C")</td>
                        <td class="actions">
                            <a asp-action="Details" asp-route-id="@item.Id">Details</a>
                            <a asp-action="Edit" asp-route-id="@item.Id">Edit</a>
                            <a class="danger-link" asp-action="Delete" asp-route-id="@item.Id">Delete</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="5" class="empty-message">No inventory items have been added yet.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
