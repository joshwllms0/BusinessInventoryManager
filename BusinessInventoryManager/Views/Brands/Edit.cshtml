@model BusinessInventoryManager.Models.Brand

@{
    ViewData["Title"] = "Edit Brand";
}

<div class="form-page">
    <div class="page-header">
        <div>
            <span class="eyebrow">Brands</span>
            <h1>Edit Brand</h1>
            <p>Update brand name or description.</p>
        </div>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>

    <div class="form-card">
        <form asp-action="Edit" method="post">
            <input type="hidden" asp-for="BrandId" />

            <div asp-validation-summary="ModelOnly"
                 class="validation-summary"></div>

            <div class="form-group">
                <label asp-for="BrandName"></label>
                <input asp-for="BrandName" />
                <span asp-validation-for="BrandName"
                      class="validation-message"></span>
            </div>

            <div class="form-group">
                <label asp-for="Description"></label>
                <textarea asp-for="Description" rows="3"></textarea>
                <span asp-validation-for="Description"
                      class="validation-message"></span>
            </div>

            <div class="button-row">
                <button type="submit" class="btn btn-primary">Save Changes</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}