@model IEnumerable<BusinessInventoryManager.Models.Brand>

@{
    ViewData["Title"] = "Brands";
}

<div class="page-header">
    <div>
        <span class="eyebrow">Manager Tools</span>
        <h1>Brands</h1>
        <p>Manage product brands available in the inventory system.</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">Add Brand</a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert-success">@TempData["SuccessMessage"]</div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert-error">@TempData["ErrorMessage"]</div>
}

<div class="table-card">
    <table class="inventory-table">
        <thead>
            <tr>
                <th>Brand Name</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Any())
            {
                foreach (var brand in Model)
                {
                    <tr>
                        <td><strong>@brand.BrandName</strong></td>
                        <td>@(brand.Description ?? "—")</td>
                        <td>
                            <div class="action-links">
                                <a asp-action="Details"
                                   asp-route-id="@brand.BrandId">Details</a>
                                <a asp-action="Edit"
                                   asp-route-id="@brand.BrandId">Edit</a>
                                <a asp-action="Delete"
                                   asp-route-id="@brand.BrandId"
                                   class="danger-link">Delete</a>
                            </div>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="3" class="empty-message">
                        No brands have been added yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>