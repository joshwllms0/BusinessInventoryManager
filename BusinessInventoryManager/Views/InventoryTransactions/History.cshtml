@model IEnumerable<BusinessInventoryManager.Models.InventoryTransaction>

@{
    ViewData["Title"] = "Stock Activity";
}

<div class="page-header">
    <div>
        <span class="eyebrow">Inventory audit trail</span>
        <h1>Stock Activity</h1>
        <p>
            Review recorded additions, removals, adjustments,
            damaged items, and expired products.
        </p>
    </div>
</div>

<div class="table-card">
    <table class="inventory-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Product</th>
                <th>Employee</th>
                <th>Type</th>
                <th>Change</th>
                <th>Previous</th>
                <th>New</th>
                <th>Notes</th>
            </tr>
        </thead>

        <tbody>
            @if (Model.Any())
            {
                foreach (var transaction in Model)
                {
                    <tr>
                        <td>
                            @transaction.TransactionDate
                                .ToLocalTime()
                                .ToString("g")
                        </td>
                        <td>@transaction.Product.ProductName</td>
                        <td>@transaction.Employee.FullName</td>
                        <td>@transaction.TransactionType</td>
                        <td>
                            @(transaction.QuantityChange > 0
                                ? $"+{transaction.QuantityChange}"
                                : transaction.QuantityChange.ToString())
                        </td>
                        <td>@transaction.PreviousQuantity</td>
                        <td>@transaction.NewQuantity</td>
                        <td>@(transaction.Notes ?? "—")</td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="8" class="empty-message">
                        No inventory activity has been recorded yet.
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>