@{
    ViewData["Title"] = "Home";
}

<section class="hero">
    <h1>Business Inventory Manager</h1>
    <p>A simple inventory system for small businesses to track products, stock levels, prices, and categories.</p>

    <div class="hero-actions">
        <a class="btn btn-primary" asp-controller="Products" asp-action="Index">View Inventory</a>
        <a class="btn btn-secondary" asp-controller="Products" asp-action="Create">Add New Item</a>
    </div>
</section>

<section class="card-grid">
    <div class="card">
        <h3>Track Stock</h3>
        <p>View current inventory levels and identify low-stock items.</p>
    </div>

    <div class="card">
        <h3>Manage Items</h3>
        <p>Create, edit, view, and delete inventory records.</p>
    </div>

    <div class="card">
        <h3>Support Decisions</h3>
        <p>Help managers understand item prices, categories, and stock value.</p>
    </div>
</section>
